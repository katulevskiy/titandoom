#!/usr/bin/env bash
# Pre-commit: auto-format staged C++ files with the project-canonical clang-format.
# Runs at commit time; reformats and re-stages so the commit is always clean.
set -euo pipefail

# Prefer clang-format-18 (matches CI / ubuntu-24.04 default).
# Falls back to unversioned clang-format so the hook never hard-blocks a developer
# who hasn't run setup yet — they'll learn about the version at push time.
if command -v clang-format-18 &>/dev/null; then
    CF=clang-format-18
elif command -v clang-format &>/dev/null; then
    CF=clang-format
else
    echo "[pre-commit] WARNING: clang-format not found — skipping auto-format." >&2
    echo "             Run scripts/setup-linux.sh (or setup-macos.sh) to install it." >&2
    exit 0
fi

STAGED=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(cpp|hpp|h)$' || true)
if [ -z "$STAGED" ]; then
    exit 0
fi

CF_VER=$("$CF" --version 2>&1 | head -1)
echo "[pre-commit] clang-format ($CF_VER): formatting staged files..."

echo "$STAGED" | xargs "$CF" -i
echo "$STAGED" | xargs git add

echo "[pre-commit] Done."
